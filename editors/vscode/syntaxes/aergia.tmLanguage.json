{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Aergia",
  "scopeName": "source.aergia",
  "patterns": [
    {
      "name": "string.quoted.double.aergia",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.aergia",
          "match": "\\\\."
        }
      ]
    },
    {
      "name": "support.function.aergia",
      "match": "(@)([a-zA-Z_][\\w.]*)",
      "captures": {
        "1": { "name": "support.function.aergia" },
        "2": { "name": "support.function.aergia" }
      }
    },
    {
      "name": "keyword.operator.comparison.aergia",
      "match": "(==|!=|<<|>>|<=|>=)"
    },
    {
      "name": "keyword.operator.logical.arithmetic.aergia",
      "match": "(~|!|&|\\||\\$|\\+|\\-|\\*|/|\\^)"
    },
    {
      "name": "keyword.operator.special.aergia",
      "match": "(\\+>|\\*>|\\*<|:|=|@|\\?|,|\\.|')"
    },
    {
      "name": "keyword.control.aergia",
      "match": "[\\[\\]\\(\\)\\{\\}]"
    },
    {
      "name": "comment.line.number-sign.aergia",
      "match": "#.*$"
    },
    {
      "name": "constant.numeric.aergia",
      "match": "\\b\\d+(\\.\\d+)?\\b"
    },
    {
      "name": "variable.other.aergia",
      "match": "\\b[a-zA-Z_][\\w.]*\\b"
    }
  ]
}